<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Appearance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:letterSpacing="0.05"
            android:text="외형"
            android:textAllCaps="true"
            android:textColor="#999999"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Scale -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="크기"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/valScale"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekScale"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="150"
                android:progress="50" />
        </LinearLayout>

        <!-- Opacity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="불투명도"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/valOpacity"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekOpacity"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="70"
                android:progress="70" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#F0F0F0" />

        <!-- Behavior -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.05"
            android:text="행동"
            android:textAllCaps="true"
            android:textColor="#999999"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Move speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="이동 속도"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/valSpeed"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="3"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekSpeed"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="4"
                android:progress="2" />
        </LinearLayout>

        <!-- Activity frequency -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="활동 빈도"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/valFreq"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="3"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekFreq"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="4"
                android:progress="2" />
        </LinearLayout>

        <!-- Sleep timeout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="수면 진입"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/valSleep"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="3분"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekSleep"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="9"
                android:progress="2" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
